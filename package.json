{
  "name": "smartlib-frontend",
  "private": true,
  "workspaces": [
    "apps/*",
    "shared-packages"
  ],
  "devDependencies": {
    "prettier": "^3.5.0"
  },
  "scripts": {
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,scss,md}\"",
    "dev:web": "npm run dev -w @smartlib/web",
    "dev:admin": "npm run dev -w @smartlib/admin",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build -w @smartlib/web",
    "build:admin": "npm run build -w @smartlib/admin",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2"
  }
}
