{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "incremental": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "src/*": [
        "./src/*"
      ],
      "@features/*": [
        "./src/features/*"
      ],
      "@lib/*": [
        "./src/lib/*"
      ],
      "@shared-packages/*": [
        "../../shared-packages/src/*"
      ]
    }
  },
  "include": [
    "../../shared-packages/src/ui/icons/CloseIcon.tsx",
    "../../shared-packages/src/ui/icons/index.ts",
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
