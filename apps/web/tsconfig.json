{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "incremental": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "src/*": ["./src/*"],
      "@global/*": ["./src/global/*"],
      "@features/*": ["./src/features/*"],
      "@entities/*": ["./src/entities/*"],
      "@widgets/*": ["./src/widgets/*"],
      "@page-components/*": ["./src/page-components/*"],
      "@shared/*": ["./src/shared/*"],
      "@shared-packages/*": ["../../shared-packages/src/*"]
    }
  },
  "include": [
    // "../../shared-packages/src/ui/icons/CloseIcon.tsx",
    // "../../shared-packages/src/ui/icons/index.ts",
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
